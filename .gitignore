*.egg-info/
dist/
build/

# Logs and temporary files
*.log
*.tmp
*.temp
*.txt
!requirements.txt

# Frontend dependencies/build outputs
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/

# Editor and OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db
